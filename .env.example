# 复制为 .env 后填写本地真实配置。不要提交 .env。

# Tushare Pro SDK token，用于 tushare.pro_api()
TUSHARE_TOKEN=your_tushare_token_here

# 可选：Tushare SDK API 代理地址。留空则使用 SDK 默认地址。
TUSHARE_PROXY_URL=https://your-tushare-proxy.example.com

# 浏览器里 tushare.pro 的登录 Cookie，仅用于 fetch-tushare-news。
# 只需要 Cookie 字符串，不要包含开头的 `Cookie:`。
TUSHARE_COOKIE=uid=...; username=...
